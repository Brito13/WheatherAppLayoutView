@model List<CityWheater>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Weather";
}


<div class="container text-center margin-top-200">
    <div class="row">
        @foreach (var city in Model)
        {
            
            <div class="col">
                <div class="card mb-3" style="max-width: 540px;">
                    <div class="row g-0">
                        <div class="col-md-4">
                                <img src="~/img/@(city.CityUniqueCode).jpg" class="img-fluid rounded-start" alt="...">                        </div>
                        <div class="col-md-8">
                            <div class="card-body">
                                <h5 class="card-title">@city.CityName</h5>
                                <p class="card-text">@city.DateAndTime.Value.ToString("yyyy-dd-M HH:mm")</p>
                                <p class="card-text"><small class="text-body-secondary">@city.Temperature ºF</small></p>
                                <a href="/Country/Details/@(city.CityUniqueCode)" class="card-link">Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>




